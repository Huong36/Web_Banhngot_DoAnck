@model IEnumerable<Web_Banhngot_DoAnck.Models.CartItem>
@{
    ViewBag.Title = "Giỏ Hàng";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
    .cart-table img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
    }

    .cart-total {
        font-size: 1.5rem;
        font-weight: bold;
        color: var(--text-dark);
    }

    .btn-cta {
        background-color: var(--accent-color);
        color: var(--text-dark);
        border: none;
        padding: 12px 25px;
        font-weight: bold;
        border-radius: 5px;
        transition: background-color 0.3s;
        font-size: 1.1rem;
    }

        .btn-cta:hover {
            background-color: var(--accent-hover);
            color: var(--text-dark);
        }

    .quantity-input-cart {
        width: 60px;
        text-align: center;
    }
</style>

<h2>@ViewBag.Title</h2>

@if (Model.Count() > 0)
{
    <table class="table table-hover cart-table">
        <thead>
            <tr>
                <th>Sản Phẩm</th>
                <th>Tên</th>
                <th>Đơn Giá</th>
                <th>Số Lượng</th>
                <th>Thành Tiền</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/Content/images/placeholder.jpg" : item.ImageUrl)" alt="@item.ProductName" />
                    </td>
                    <td class="align-middle">@item.ProductName</td>
                    <td class="align-middle">@string.Format("{0:N0} VNĐ", item.Price)</td>
                    <td class="align-middle">
                        @using (Html.BeginForm("UpdateCart", "Cart", new { id = item.ProductId }, FormMethod.Post, new { @class = "form-inline" }))
                        {
                            <input type="number" name="quantity" class="form-control quantity-input-cart mr-2" value="@item.Quantity" min="1" max="99" />
                            <button type="submit" class="btn btn-sm btn-outline-dark" style="display:none;">Cập nhật</button>
                        }
                    </td>
                    <td class="align-middle">@string.Format("{0:N0} VNĐ", item.Total)</td>
                    <td class="align-middle">
                        @Html.ActionLink("Xóa", "RemoveFromCart", new { id = item.ProductId }, new { @class = "btn btn-sm btn-danger" })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="row" style="margin-top: 30px;">
        <div class="col-md-8">
        </div>
        <div class="col-md-4 text-right">
            <h4 class="cart-total">Tổng Cộng: @string.Format("{0:N0} VNĐ", ViewBag.TotalAmount)</h4>
            <a href="@Url.Action("Index", "Checkout")" class="btn btn-cta btn-block mt-3">Tiến hành Thanh toán</a>
        </div>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        Giỏ hàng của bạn đang trống.
    </div>
    @Html.ActionLink("Quay lại mua sắm", "Index", "Products", null, new { @class = "btn btn-primary" })
}

@{
    var cartRecommendations = ViewBag.CartRecommendations as List<Web_Banhngot_DoAnck.Models.Product>;
}

@if (cartRecommendations != null && cartRecommendations.Any())
{
    <div style="margin-top: 40px; padding-top: 20px; border-top: 2px solid #eee;">
        <h4 style="color: var(--text-dark); margin-bottom: 20px;">
            <i class="fas fa-lightbulb" style="color: #FFD700;"></i> Gợi ý mua thêm cho bạn
        </h4>
        <div class="row">
            @foreach (var p in cartRecommendations)
            {
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card h-100" style="border: 1px solid #eee; border-radius: 8px; overflow: hidden; transition: transform 0.3s; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                        <a href="@Url.Action("Details", "Products", new { id = p.Id })" style="text-decoration: none; color: inherit;">
                            <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/Content/images/placeholder.jpg" : p.ImageUrl)"
                                 class="card-img-top" alt="@p.Name" style="height: 180px; object-fit: cover;">
                            <div class="card-body" style="padding: 10px;">
                                <h6 class="card-title" style="font-size: 0.95rem; height: 2rem; overflow: hidden;">@p.Name</h6>
                                <p class="card-text text-danger font-weight-bold" style="margin: 0;">@string.Format("{0:N0} VNĐ", p.Price)</p>
                            </div>
                        </a>
                        <div class="card-footer bg-white border-0 text-center pb-2">
                            @using (Html.BeginForm("AddToCart", "Cart", new { id = p.Id }, FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm" style="background-color: var(--accent-color); color: white; width: 100%;">
                                    <i class="fas fa-cart-plus"></i> Thêm nhanh
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section scripts {
    <script>
        $(document).ready(function () {
            $('.quantity-input-cart').on('change', function () {
                $(this).closest('form').submit();
            });
        });
    </script>
}
