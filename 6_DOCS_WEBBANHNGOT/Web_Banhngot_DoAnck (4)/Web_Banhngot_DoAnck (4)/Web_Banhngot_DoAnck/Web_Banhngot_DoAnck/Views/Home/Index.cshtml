@model IEnumerable<Web_Banhngot_DoAnck.Models.Product>
@{
    ViewBag.Title = "Trang Chủ";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
    /* CSS cho Carousel */
    .carousel-item {
        height: 500px; /* Chiều cao cố định cho banner */
    }

        .carousel-item img {
            height: 100%;
            width: 100%;
            object-fit: cover; /* Đảm bảo ảnh phủ kín khung mà không bị méo */
            object-position: center;
        }

    /* Nền đen mờ cho chữ dễ đọc hơn */
    .carousel-caption {
        background-color: rgba(0, 0, 0, 0.5);
        padding: 20px;
        border-radius: 10px;
        bottom: 20%; /* Vị trí của chữ */
    }

        .carousel-caption h1 {
            font-weight: bold;
            font-size: 3rem;
            color: #fff;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .carousel-caption p {
            font-size: 1.5rem;
            color: #f8f9fa;
        }
</style>

<div id="homeCarousel" class="carousel slide" data-ride="carousel" style="margin-bottom: 30px;">
    <ol class="carousel-indicators">
        <li data-target="#homeCarousel" data-slide-to="0" class="active"></li>
        <li data-target="#homeCarousel" data-slide-to="1"></li>
        <li data-target="#homeCarousel" data-slide-to="2"></li>
    </ol>

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1565958011703-44f9829ba187?ixlib=rb-1.2.1&auto=format&fit=crop&w=1000&q=80" class="d-block w-100" alt="Bánh Kem Dâu">
            <div class="carousel-caption d-none d-md-block">
                <h1>SweetBaker</h1>
                <p>Nơi hương vị ngọt ngào bắt đầu.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1555507036-ab1f4038808a?ixlib=rb-1.2.1&auto=format&fit=crop&w=1000&q=80" class="d-block w-100" alt="Bánh Mì Tươi">
            <div class="carousel-caption d-none d-md-block">
                <h1>Các Mẫu Bánh Mới</h1>
                <p>Cập Nhập liên tục theo thị trường.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="https://cdn2.fptshop.com.vn/unsafe/1920x0/filters:format(webp):quality(75)/banh_ngon_ha_noi_b92a6073cb.jpg" class="d-block w-100" alt="Tiệc Ngọt">
            <div class="carousel-caption d-none d-md-block">
                <h1>Nhận làm bánh theo yêu cầu</h1>
                <p>Liên hệ ngay tại</p>
                <a>@Html.ActionLink("Liên Hệ", "Contact", "Home", null, new { @class = "nav-link" })</a>
            </div>
        </div>
    </div>

    <a class="carousel-control-prev" href="#homeCarousel" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>

    <a class="carousel-control-next" href="#homeCarousel" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>
</div>

<div class="row">
    <div class="col-md-12">
        <h2 style="color: var(--text-dark); border-bottom: 2px solid var(--accent-color); padding-bottom: 10px; margin-bottom: 20px;">
            Sản Phẩm Mới Nhất
        </h2>
    </div>
</div>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            @Html.Partial("_ProductCard", product)
        </div>
    }
</div>