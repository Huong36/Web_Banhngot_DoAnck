@{
    ViewBag.Title = "Quản lý Khai phá dữ liệu (Apriori)";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<div class="container mt-4">
    <h2 style="border-bottom: 3px solid var(--accent-color); padding-bottom: 10px;">
        <i class="fas fa-brain"></i> Quản lý Huấn luyện Mô hình Đề xuất Sản phẩm
    </h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" style="margin-top: 15px;">
            <i class="fas fa-check-circle"></i> @TempData["Message"]
        </div>
    }

    <!-- Thẻ thống kê tổng quan -->
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white mb-3" style="background-color: #5C6BC0;">
                <div class="card-body text-center">
                    <i class="fas fa-box-open fa-2x"></i>
                    <h5 class="card-title mt-2">Tổng Sản phẩm</h5>
                    <p class="card-text" style="font-size: 2rem; font-weight: bold;">@ViewBag.TotalProducts</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white mb-3" style="background-color: #26A69A;">
                <div class="card-body text-center">
                    <i class="fas fa-shopping-bag fa-2x"></i>
                    <h5 class="card-title mt-2">Tổng Đơn hàng</h5>
                    <p class="card-text" style="font-size: 2rem; font-weight: bold;">@ViewBag.TotalOrders</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white mb-3" style="background-color: #EF5350;">
                <div class="card-body text-center">
                    <i class="fas fa-project-diagram fa-2x"></i>
                    <h5 class="card-title mt-2">Luật Gợi ý đã sinh</h5>
                    <p class="card-text" style="font-size: 2rem; font-weight: bold;">@ViewBag.TotalRules</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Hai nút chức năng chính -->
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header" style="background-color: #E3F2FD;">
                    <h4><i class="fas fa-database"></i> Bước 1: Chuẩn bị Dữ liệu</h4>
                </div>
                <div class="card-body">
                    <p>Sinh tự động 300 sản phẩm mới và 5.000 đơn hàng có cài sẵn quy luật mua kèm ẩn để thuật toán phát hiện.</p>
                    <p class="text-muted"><small><i class="fas fa-info-circle"></i> 30 sản phẩm gốc ban đầu sẽ được giữ lại.</small></p>
                    @using (Html.BeginForm("SeedData", "DataMining", FormMethod.Post))
                    {
                        <button type="submit" class="btn btn-primary btn-block" onclick="return confirm('Bạn có chắc chắn muốn sinh dữ liệu mới? Dữ liệu giả cũ sẽ bị xóa.');">
                            <i class="fas fa-cogs"></i> Tiến hành Sinh Dữ liệu
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header" style="background-color: #E8F5E9;">
                    <h4><i class="fas fa-brain"></i> Bước 2: Huấn luyện Apriori</h4>
                </div>
                <div class="card-body">
                    <p>Quét toàn bộ lịch sử mua hàng, tìm tập phổ biến và sinh luật kết hợp (Association Rules).</p>
                    @using (Html.BeginForm("RunApriori", "DataMining", FormMethod.Post))
                    {
                        <div class="form-group">
                            <label>Min Support:</label>
                            <input type="text" name="minSupport" value="0.005" class="form-control form-control-sm" />
                            <small class="text-muted">Tần suất xuất hiện tối thiểu (0.005 = 0.5%)</small>
                        </div>
                        <div class="form-group mt-2">
                            <label>Min Confidence:</label>
                            <input type="text" name="minConfidence" value="0.3" class="form-control form-control-sm" />
                            <small class="text-muted">Độ tin cậy tối thiểu (0.3 = 30%)</small>
                        </div>
                        <button type="submit" class="btn btn-success btn-block mt-3">
                            <i class="fas fa-play"></i> Bắt đầu Huấn luyện (Train AI)
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Nút xem báo cáo chi tiết -->
    @if ((int)ViewBag.TotalRules > 0)
    {
        <div class="text-center mt-4">
            <a href="@Url.Action("Report", "DataMining")" class="btn btn-outline-dark btn-lg">
                <i class="fas fa-chart-bar"></i> Xem Báo cáo Phân tích Chi tiết
            </a>
        </div>
    }

    <!-- Bảng Top 20 luật kết hợp -->
    @{
        var topRules = ViewBag.TopRules as List<Web_Banhngot_DoAnck.Models.ProductRecommendation>;
    }
    @if (topRules != null && topRules.Any())
    {
        <div class="mt-4">
            <h4 style="border-bottom: 2px solid var(--accent-color); padding-bottom: 8px;">
                <i class="fas fa-list-ol"></i> Top 20 Luật Kết hợp mạnh nhất
            </h4>
            <div class="table-responsive">
                <table class="table table-striped table-hover mt-2">
                    <thead style="background-color: var(--text-dark); color: white;">
                        <tr>
                            <th>#</th>
                            <th>Sản phẩm A (Khi mua)</th>
                            <th></th>
                            <th>Sản phẩm B (Gợi ý mua kèm)</th>
                            <th>Support</th>
                            <th>Confidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int idx = 1;}
                        @foreach (var rule in topRules)
                        {
                            <tr>
                                <td>@idx</td>
                                <td>
                                    @if (rule.ProductA != null)
                                    {
                                        @rule.ProductA.Name
                                    }
                                    else
                                    {
                                        <span class="text-muted">ID: @rule.ProductId_A</span>
                                    }
                                </td>
                                <td style="font-size: 1.3rem; color: #EF5350;">→</td>
                                <td>
                                    @if (rule.ProductB != null)
                                    {
                                        @rule.ProductB.Name
                                    }
                                    else
                                    {
                                        <span class="text-muted">ID: @rule.ProductId_B</span>
                                    }
                                </td>
                                <td>@string.Format("{0:P2}", rule.Support)</td>
                                <td>
                                    <div class="progress" style="height: 22px; min-width: 120px;">
                                        <div class="progress-bar @(rule.Confidence >= 0.7 ? "bg-success" : rule.Confidence >= 0.5 ? "bg-warning" : "bg-info")"
                                             role="progressbar"
                                             style="width: @string.Format("{0:0}%", rule.Confidence * 100);"
                                             aria-valuenow="@(rule.Confidence * 100)"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                            @string.Format("{0:P1}", rule.Confidence)
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            idx++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
