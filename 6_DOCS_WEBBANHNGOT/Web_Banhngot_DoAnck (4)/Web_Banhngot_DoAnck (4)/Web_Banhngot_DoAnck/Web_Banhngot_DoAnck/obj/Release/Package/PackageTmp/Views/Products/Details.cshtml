@model Web_Banhngot_DoAnck.Models.Product
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
    .detail-img {
        width: 100%;
        border-radius: 8px;
        border: 1px solid #eee;
    }

    .detail-price {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--accent-color);
    }

    .detail-category {
        font-size: 1.1rem;
        background-color: var(--bg-main);
        padding: 5px 10px;
        border-radius: 5px;
        display: inline-block;
    }

    .btn-cta {
        background-color: var(--accent-color);
        color: var(--text-dark);
        border: none;
        padding: 12px 25px;
        font-weight: bold;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s;
        font-size: 1.1rem;
    }

        .btn-cta:hover {
            background-color: var(--accent-hover);
            color: var(--text-dark);
        }

    .quantity-selector {
        display: flex;
        align-items: center;
        margin-right: 20px;
    }

    .quantity-btn {
        background-color: #eee;
        border: 1px solid #ccc;
        color: var(--text-dark);
        cursor: pointer;
        font-size: 1.2rem;
        font-weight: bold;
        height: 48px;
        width: 40px;
    }

        .quantity-btn:hover {
            background-color: #ddd;
        }

    .quantity-input {
        width: 60px;
        height: 48px;
        text-align: center;
        border: 1px solid #ccc;
        border-left: none;
        border-right: none;
        font-size: 1.1rem;
        font-weight: bold;
        -moz-appearance: textfield;
    }

        .quantity-input::-webkit-outer-spin-button,
        .quantity-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
</style>

<div class="row" style="margin-top: 20px;">
    <div class="col-md-6">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/Content/images/placeholder.jpg" : Model.ImageUrl)"
             alt="@Model.Name" class="detail-img" />
    </div>
    <div class="col-md-6">
        @using (Html.BeginForm("AddToCart", "Cart", new { id = Model.Id }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <h1 style="color: var(--text-dark);">@Model.Name</h1>

            <p class="detail-category">
                <strong>Loại:</strong> @Model.Category.Name
            </p>

            <p class="detail-price" style="margin-top: 20px;">
                @string.Format("{0:N0} VNĐ", Model.Price)
            </p>

            <p style="font-size: 1.1rem; margin-top: 20px;">
                @Model.Description
            </p>

            <div style="margin-top: 30px; display: flex; align-items: center;">
                <div class="quantity-selector">
                    <button type="button" class="quantity-btn" id="btn-minus">-</button>
                    <input type="number" name="quantity" id="quantity-input" class="quantity-input" value="1" min="1" max="99">
                    <button type="button" class="quantity-btn" id="btn-plus">+</button>
                </div>

                <button type="submit" class="btn btn-cta">
                    <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                </button>
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            var $input = $('#quantity-input');
            var $btnPlus = $('#btn-plus');
            var $btnMinus = $('#btn-minus');

            $btnPlus.click(function () {
                var currentVal = parseInt($input.val());
                if (!isNaN(currentVal) && currentVal < 99) {
                    $input.val(currentVal + 1);
                } else {
                    $input.val(99);
                }
            });

            $btnMinus.click(function () {
                var currentVal = parseInt($input.val());
                if (!isNaN(currentVal) && currentVal > 1) {
                    $input.val(currentVal - 1);
                } else {
                    $input.val(1);
                }
            });

            $input.on('input', function () {
                var currentVal = parseInt($input.val());
                if (isNaN(currentVal) || currentVal < 1) {
                    $input.val(1);
                } else if (currentVal > 99) {
                    $input.val(99);
                }
            });
        });
    </script>
}