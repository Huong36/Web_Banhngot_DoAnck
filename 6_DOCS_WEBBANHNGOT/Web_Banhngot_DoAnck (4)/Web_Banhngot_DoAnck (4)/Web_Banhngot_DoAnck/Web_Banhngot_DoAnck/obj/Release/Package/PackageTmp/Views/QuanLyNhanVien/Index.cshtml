@model IEnumerable<Web_Banhngot_DoAnck.Models.ApplicationUser>
        @{

        ViewBag.Title = "Index";

        Layout = "~/Views/Shared/_LayoutPage.cshtml";

        }

    <h2>@ViewBag.Title</h2>

    <p>
        @Html.ActionLink("Tạo Nhân Viên Mới", "Create", null, new { @class = "btn btn-primary" })
    </p>
    <table class="table table-bordered table-hover">
        <tr>
            <th>
                Tên Đăng Nhập
            </th>
            <th>
                Email
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.UserName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td>
                    @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-warning btn-sm" }) |
                    @Html.ActionLink("Xóa", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </table>
